# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartfinanceai
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=ganti_dengan_secret_yang_kuat_minimal_32_karakter
JWT_EXPIRES_IN=7d

# ─── OTP ──────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ─── Email (Nodemailer) ───────────────────────────────────
# Gunakan Gmail App Password (bukan password Gmail biasa)
# Aktifkan 2FA Gmail → https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM="SmartFinance AI <your_email@gmail.com>"

# ─── Redis (Memurai untuk Windows, Redis untuk Linux/Mac) ─
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Frontend URL (untuk CORS) ────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── SmartFinance AI Python API ───────────────────────────
# URL Classification API (Python, port 8002)
CLASSIFY_API_URL=http://localhost:8002
# URL Recommendation API (Python, port 8001) — opsional, referensi saja
RECOMMENDATION_API_URL=http://localhost:8001
# API key untuk autentikasi ke Python API (kosongkan jika dev mode)
SMARTFINANCE_API_KEY=
